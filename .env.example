# PaperLight environment template — PRD §7.5.3
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# === API Keys (Secrets only) ===
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
ELEVENLABS_API_KEY=
COHERE_API_KEY=

# === Infra ===
# DATABASE_URL: 미설정 시 SQLite (sqlite+aiosqlite:///./paperlight.db) — Phase 0 호환 default.
# Postgres 사용 시 async driver 명시 필요 (`+asyncpg`).
DATABASE_URL=postgresql+asyncpg://paperlight:paperlight@localhost:5432/paperlight
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=paperlight
S3_SECRET_KEY=paperlight
S3_BUCKET=paperlight-dev

# === App ===
APP_ENV=development            # development | staging | production
LOG_LEVEL=INFO
# JWT_SECRET — production에서 필수. development에서 비어 있으면 in-memory dev fallback 사용.
JWT_SECRET=change-me-in-production

# === Auth (Phase 1 S7b) ===
# Google OAuth client (실 OAuth 진입 시 발급, 현재 stub/mock 모드). 둘 다 채우면 /api/auth/login/google가 501(미구현)로 응답, 비어 있으면 503 + mock-login 안내.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Mock login endpoint는 APP_ENV=development거나 PAPERLIGHT_ALLOW_MOCK_LOGIN=1일 때만 노출.
PAPERLIGHT_ALLOW_MOCK_LOGIN=

# === Ingestion (Phase 1 S8/S9) ===
# INGEST_PARSER: pymupdf(기본, 경량) | marker(수식, follow-up — 미구현 시 NotImplementedError).
INGEST_PARSER=pymupdf
# INGEST_EMBEDDER: stub(기본, 결정적 dim=1024 — 오프라인) | fastembed(bge-m3 ONNX, `uv sync --extra ingest` 필요).
INGEST_EMBEDDER=stub
INGEST_EMBED_MODEL=BAAI/bge-m3
# PAPERLIGHT_FIXTURES_DIR: arXiv import fixture-first 조회 경로 override (미설정 시 repo의 fixtures/pilot-papers).
PAPERLIGHT_FIXTURES_DIR=
# PAPERLIGHT_PUBLIC_URL: Local object store presigned URL의 base (S3/MinIO 미사용 dev/test 전용).
PAPERLIGHT_PUBLIC_URL=http://localhost:8000
# S3_ENDPOINT 가 설정되면 object store는 S3(MinIO/R2), 비어 있으면 in-process Local 백엔드.
