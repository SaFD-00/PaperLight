# PaperLight environment template — single-user local AI paper reader.
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# === LLM API Keys (set the provider you use; see config/agents.yaml) ===
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# === App ===
APP_ENV=development            # development | staging | production
LOG_LEVEL=INFO

# === Storage (local) ===
# DATABASE_URL: SQLite only. 미설정 시 ./paperlight.db.
DATABASE_URL=sqlite+aiosqlite:///./paperlight.db
# PAPERLIGHT_DATA_DIR: 원본 PDF·노트 백업이 저장되는 로컬 디렉터리.
PAPERLIGHT_DATA_DIR=./data
# PAPERLIGHT_PUBLIC_URL: pdf.js iframe이 PDF를 로드하는 백엔드 base URL.
PAPERLIGHT_PUBLIC_URL=http://localhost:8000

# === Ingestion ===
# INGEST_PARSER: pymupdf(기본, 경량) | marker(정밀 figure/table bbox, `uv sync --extra marker`).
INGEST_PARSER=pymupdf
# INGEST_EMBEDDER: stub(기본, 결정적 dim=1024 — 오프라인) | fastembed(bge-m3, `uv sync --extra ingest`).
INGEST_EMBEDDER=stub
INGEST_EMBED_MODEL=BAAI/bge-m3
# PAPERLIGHT_FIXTURES_DIR: arXiv import fixture-first 조회 경로 override (미설정 시 fixtures/pilot-papers).
PAPERLIGHT_FIXTURES_DIR=
# PAPERLIGHT_SEED_SAMPLES: 파일럿 샘플 논문(sample-1/2)을 startup에 시드. development면 자동 on, 그 외 =1로 opt-in.
PAPERLIGHT_SEED_SAMPLES=
