# PaperLight environment template — PRD §7.5.3
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# === API Keys (Secrets only) ===
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
ELEVENLABS_API_KEY=
COHERE_API_KEY=

# === Infra ===
DATABASE_URL=postgresql://paperlight:paperlight@localhost:5432/paperlight
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=paperlight
S3_SECRET_KEY=paperlight
S3_BUCKET=paperlight-dev

# === App ===
APP_ENV=development            # development | staging | production
LOG_LEVEL=INFO
JWT_SECRET=change-me-in-production
